.sub-btn{width:100%;background:var(--accent);color:#fff;font-family:'Syne',sans-serif;font-weight:700;font-size:.85rem;letter-spacing:.05em;padding:13px;border:none;cursor:pointer;text-transform:uppercase;transition:background .2s;margin-top:.3rem}

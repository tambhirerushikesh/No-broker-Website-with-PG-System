const pgList=[
  {n:'Sunrise PG – Baner',m:'Single Sharing · WiFi · Food · AC · Security',p:'₹7,500'},
  {n:'Green Nest PG – Wakad',m:'Double Sharing · WiFi · 24hr Security · Laundry',p:'₹5,200'},
  {n:'City View PG – Hinjewadi',m:'Triple Sharing · Food · Gym · Laundry · Geyser',p:'₹4,800'},
  {n:"Scholar's Den – Shivajinagar",m:'Single · WiFi · Food · 24hr CCTV · AC',p:'₹8,000'},
  {n:'Metro PG – Kothrud',m:'Double Sharing · AC · Parking · WiFi · Meals',p:'₹6,500'},
  {n:'Girls PG – Viman Nagar',m:'Single · Food · WiFi · AC · Geyser · Security',p:'₹7,200'},
];
const tickerData=[
  '🏠 2BHK in Kothrud, Pune – ₹18,000/mo | Available Now',
  '🏘️ PG in Baner for Ladies – ₹7,500/mo | WiFi + Food + AC',
  '🏡 3BHK Villa in Jubilee Hills – ₹38,000/mo | Fully Furnished',
  '🌊 Sea-View 2BHK in Bandra – ₹45,000/mo | Luxury Living',
  '⚡ Studio in Koramangala – ₹18,000/mo | Move-in Ready',
  '✅ All listings 100% Owner Direct | Zero Brokerage Guaranteed',
  '🎓 Student PG Starting ₹4,800/mo | Meals Included',
  '📍 Properties in 15+ Cities | New Listings Added Daily',
];

/* ── STATE ── */
let user=null, curCity='Pune';

/* ── TICKER ── */
const tr=document.getElementById('ticker-track');
const all=[...tickerData,...tickerData];
tr.innerHTML=all.map(t=>`<span class="tick-item"><span class="tick-dot"></span>${t}</span>`).join('');

/* ── CITIES ── */
function renderCities(){
  document.getElementById('city-tabs').innerHTML=cities.map(c=>`<button class="ctab${c.n===curCity?' active':''}" onclick="setCity('${c.n}')">${c.n}</button>`).join('');
  const cur=cities.find(x=>x.n===curCity);
  document.getElementById('city-meta').innerHTML=`Showing properties in <strong>${curCity}</strong> — <strong>${cur?cur.c.toLocaleString():0}</strong> listings available`;
}
function setCity(c){curCity=c;renderCities();renderProps(props.filter(p=>p.city===c));}
renderCities();

/* ── RENDER PROPERTIES ── */
function renderProps(list){
  const g=document.getElementById('prop-grid');
  if(!list.length){g.innerHTML=`<div style="grid-column:1/-1;text-align:center;padding:3rem;color:var(--muted)">No properties match your filters. <a href="#" onclick="resetSearch()" style="color:var(--accent);font-weight:600">Clear filters</a></div>`;return;}
  g.innerHTML=list.map(p=>`
    <div class="pc fade">
      <div class="pc-thumb ${p.col}">${p.icon}<div class="pc-tag${p.tag==='pg'?' pg':''}">${p.tag==='pg'?'PG':p.type}</div></div>
      <div class="pc-body">
        <div class="pc-name">${p.name}</div>
        <div class="pc-loc">📍 ${p.loc} &nbsp;·&nbsp; ${p.bhk} &nbsp;·&nbsp; ${p.furn}</div>
        <div class="pc-chips">${p.chips.map(c=>`<span class="chip">${c}</span>`).join('')}</div>
        <div class="pc-ft">
          <div class="pc-price">₹${p.price.toLocaleString()} <small>/mo</small></div>
          <button class="c-btn" onclick="contactOwner(${p.id})">Contact Owner</button>
        </div>
      </div>
    </div>`).join('');
  observeFades();
}
renderProps(props.filter(p=>p.city==='Pune'));

/* ── PG ROOMS ── */
document.getElementById('pg-rooms').innerHTML=pgList.map(r=>`
  <div class="pg-room">
    <div><div class="pg-rn">${r.n}</div><div class="pg-rm">${r.m}</div></div>
    <div class="pg-rp">${r.p}<span style="font-size:.65rem;opacity:.55">/mo</span></div>
  </div>`).join('');

/* ── SEARCH ── */
function doSearch(){
  const city=document.getElementById('s-city').value.toLowerCase().trim();
  const type=document.getElementById('s-type').value;
  const bhk=document.getElementById('s-bhk').value;
  const budget=document.getElementById('s-budget').value;
  let res=[...props];
  if(city) res=res.filter(p=>p.loc.toLowerCase().includes(city)||p.city.toLowerCase().includes(city)||p.name.toLowerCase().includes(city));
  if(type){
    if(type.includes('PG')) res=res.filter(p=>p.type==='PG');
    else if(type.includes('House')) res=res.filter(p=>p.type==='House');
    else if(type.includes('Studio')) res=res.filter(p=>p.type==='Studio');
    else if(type.includes('Villa')) res=res.filter(p=>p.type==='House');
    else res=res.filter(p=>p.type==='Flat'||p.type==='Studio');
  }
  if(bhk) res=res.filter(p=>p.bhk===bhk);
  if(budget){const[mn,mx]=budget.split('-').map(Number);res=res.filter(p=>p.price>=mn&&p.price<=mx);}
  renderProps(res);
  document.getElementById('properties').scrollIntoView({behavior:'smooth'});
  if(!res.length) toast('No matching properties — try different filters','err');
}
function filterPG(){
  document.getElementById('s-type').value='PG Accommodation';
  doSearch();
}
function resetSearch(){
  ['s-city','s-type','s-bhk','s-budget','s-furn'].forEach(id=>{const e=document.getElementById(id);if(e)e.value='';});
  renderProps(props);
}

/* ── MODALS ── */
function openModal(id){document.getElementById(id).classList.add('open');document.body.style.overflow='hidden';}
function closeModal(id){document.getElementById(id).classList.remove('open');document.body.style.overflow='';}
function switchModals(from,to){closeModal(from);setTimeout(()=>openModal(to),150);}
document.querySelectorAll('.overlay').forEach(o=>o.addEventListener('click',e=>{if(e.target===o)closeModal(o.id);}));

/* ── TABS ── */
function switchTab(btn,target){
  btn.closest('.tab-row').querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  btn.classList.add('active');
  ['reg-tenant','reg-owner','lt-flat','lt-pg'].forEach(id=>{
    const el=document.getElementById(id);
    if(el) el.style.display=id===target?'block':'none';
  });
}

/* ── AUTH ── */
function doLogin(){
  const email=document.getElementById('l-email').value.trim();
  const pass=document.getElementById('l-pass').value;
  const al=document.getElementById('login-alert');
  if(!email||!pass){showAlert(al,'Please enter your email and password.','err');return;}
  if(!email.includes('@')){showAlert(al,'Please enter a valid email address.','err');return;}
  if(pass.length<6){showAlert(al,'Password must be at least 6 characters.','err');return;}
  const name=email.split('@')[0].replace(/[._-]/g,' ').split(' ').map(w=>w.charAt(0).toUpperCase()+w.slice(1)).join(' ')||'User';
  loginUser({name,email,init:name[0].toUpperCase(),role:'tenant'});
  closeModal('login-modal');
  toast(`Welcome back, ${name.split(' ')[0]}! 🎉`);
}
function doRegister(role){
  const al=document.getElementById('reg-alert');
  const p=role==='tenant'?'t':'o';
  const fn=document.getElementById(`${p}-fn`).value.trim();
  const ln=document.getElementById(`${p}-ln`).value.trim();
  const email=document.getElementById(`${p}-email`).value.trim();
  const phone=document.getElementById(`${p}-phone`).value.trim();
  if(!fn||!ln||!email||!phone){showAlert(al,'Please fill in all required fields.','err');return;}
  if(!email.includes('@')){showAlert(al,'Please enter a valid email address.','err');return;}
  loginUser({name:`${fn} ${ln}`,email,init:fn[0].toUpperCase(),role});
  closeModal('reg-modal');
  toast(`Welcome to NoBroker, ${fn}! Your account is ready 🎉`);
}
function googleSignIn(){
  loginUser({name:'Google User',email:'user@gmail.com',init:'G',role:'tenant'});
  closeModal('login-modal');closeModal('reg-modal');
  toast('Signed in with Google! Welcome to NoBroker 🎉');
}
function loginUser(u){
  user=u;
  document.getElementById('nav-auth').style.display='none';
  const av=document.getElementById('nav-avatar');
  av.style.display='flex';
  document.getElementById('av-init').textContent=u.init;
  document.getElementById('av-nm').textContent=u.name.split(' ')[0];
  document.getElementById('drop-fullname').textContent=u.name;
  document.getElementById('drop-email').textContent=u.email;
  document.getElementById('dash-nm').textContent=u.name.split(' ')[0];
  document.getElementById('dash-banner').style.display='block';
  document.getElementById('mob-btns').innerHTML=`<button class="btn-o" onclick="doLogout(event);closeMob()">Log Out (${u.name.split(' ')[0]})</button>`;
}
function doLogout(e){
  if(e) e.preventDefault();
  user=null;
  document.getElementById('nav-auth').style.display='flex';
  const av=document.getElementById('nav-avatar');
  av.style.display='none';av.classList.remove('open');
  document.getElementById('dash-banner').style.display='none';
  document.getElementById('mob-btns').innerHTML=`
    <button class="btn-o" onclick="openModal('login-modal');closeMob()">Log In</button>
    <button class="btn-p" onclick="openModal('reg-modal');closeMob()">Register Free</button>`;
  toast('Logged out successfully. See you soon!');
}
function toggleDrop(){document.getElementById('nav-avatar').classList.toggle('open');}
document.addEventListener('click',e=>{
  const av=document.getElementById('nav-avatar');
  if(av&&!av.contains(e.target)) av.classList.remove('open');
});

/* ── CONTACT ── */
function contactOwner(id){
  if(!user){toast('Please log in to contact the owner.','err');setTimeout(()=>openModal('login-modal'),600);return;}
  toast('Owner details shared! Connecting you directly — zero broker fee ✅');
}

/* ── LIST ── */
function doListing(){
  if(!user){closeModal('list-modal');toast('Please log in to list your property.','err');setTimeout(()=>openModal('login-modal'),600);return;}
  closeModal('list-modal');
  toast('Listing submitted! We\'ll review and publish within 24 hours ✅');
}

/* ── HELPERS ── */
function showAlert(el,msg,type='ok'){
  el.textContent=msg;el.style.display='block';
  el.className='form-alert'+(type==='err'?' err':'');
}
function pwdStrength(inp,hintId){
  const h=document.getElementById(hintId);if(!h)return;
  const len=inp.value.length;
  if(!len){h.textContent='';h.style.color='';return;}
  if(len<6){h.textContent='Too short — min. 8 characters';h.style.color='var(--accent)';}
  else if(len<8){h.textContent='Almost there…';h.style.color='var(--accent2)';}
  else{h.textContent='✓ Strong password';h.style.color='var(--green)';}
}
function toast(msg,type=''){
  const t=document.getElementById('toast');
  t.textContent=msg;t.className='toast'+(type==='err'?' err':'');
  t.classList.add('show');
  clearTimeout(t._t);
  t._t=setTimeout(()=>t.classList.remove('show'),3800);
}

/* ── NAV ── */
window.addEventListener('scroll',()=>{
  document.getElementById('main-nav').classList.toggle('scrolled',scrollY>10);
},{passive:true});
function toggleMob(){document.getElementById('mob-menu').classList.toggle('open');}
function closeMob(){document.getElementById('mob-menu').classList.remove('open');}

/* ── SCROLL ANIM ── */
function observeFades(){
  const io=new IntersectionObserver((entries)=>{
    entries.forEach((e,i)=>{if(e.isIntersecting)setTimeout(()=>e.target.classList.add('vis'),i*70);});
  },{threshold:.1});
  document.querySelectorAll('.fade:not(.vis)').forEach(el=>io.observe(el));
}
observeFades();
</script>

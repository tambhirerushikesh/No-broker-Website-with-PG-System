  {id:10,name:'2BHK – HSR Layout',loc:'HSR Layout, Bangalore',city:'Bangalore',price:25000,type:'Flat',bhk:'2 BHK',furn:'Semi-Furnished',chips:['Parking','Lift','Society'],col:'c1',icon:'🏠',tag:'Flat'},
  {id:11,name:'Ladies PG – Koramangala',loc:'Koramangala, Bangalore',city:'Bangalore',price:8500,type:'PG',bhk:'Single',furn:'Furnished',chips:['Food','WiFi','CCTV','AC'],col:'c2',icon:'🏘️',tag:'pg'},
  {id:12,name:'3BHK Villa – Jubilee Hills',loc:'Jubilee Hills, Hyderabad',city:'Hyderabad',price:38000,type:'House',bhk:'3 BHK',furn:'Fully Furnished',chips:['Private Garden','Security','Pool'],col:'c3',icon:'🏰',tag:'House'},
  {id:13,name:'2BHK – Whitefield',loc:'Whitefield, Bangalore',city:'Bangalore',price:20000,type:'Flat',bhk:'2 BHK',furn:'Fully Furnished',chips:['IT Hub','WiFi','Parking'],col:'c4',icon:'🏢',tag:'Flat'},

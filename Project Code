.pwd-hint{font-size:.69rem;margin-top:4px}
.form-alert{padding:.72rem 1rem;font-size:.81rem;margin-bottom:1rem;border-left:3px solid var(--green);background:rgba(22,163,74,.07);color:var(--green);display:none}
.form-alert.err{border-color:var(--accent);background:rgba(232,65,24,.07);color:var(--accent)}

/* TOAST */
.toast{position:fixed;bottom:2rem;right:2rem;z-index:2000;background:var(--ink);color:var(--paper);padding:.9rem 1.4rem;font-family:'Syne',sans-serif;font-weight:600;font-size:.83rem;border-left:4px solid var(--green);transform:translateX(140%);transition:transform .35s;max-width:300px;box-shadow:0 8px 24px rgba(0,0,0,.2)}
.toast.show{transform:translateX(0)}
.toast.err{border-left-color:var(--accent)}

/* SCROLL ANIM */
.fade{opacity:0;transform:translateY(16px);transition:opacity .6s ease,transform .6s ease}
.fade.vis{opacity:1;transform:translateY(0)}


<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>NoBroker PG — India's #1 Zero Brokerage Platform</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
:root{
  --ink:#0d1117; --paper:#f5f0e8; --accent:#e84118; --accent2:#f5a623;
  --muted:#6b6b6b; --card:#ffffff; --border:#e0dbd0;
  --green:#16a34a; --nav-h:68px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--paper);color:var(--ink);overflow-x:hidden}

/* TICKER */
.ticker{background:var(--ink);padding:6px 0;overflow:hidden;white-space:nowrap}
.ticker-track{display:inline-flex;gap:3rem;animation:tick 30s linear infinite}
@keyframes tick{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.tick-item{display:inline-flex;align-items:center;gap:.45rem;font-size:.71rem;color:rgba(245,240,232,.65);font-weight:500;letter-spacing:.03em}
.tick-dot{width:5px;height:5px;background:var(--accent2);border-radius:50%;flex-shrink:0}

/* NAV */
nav{position:sticky;top:0;z-index:300;display:flex;align-items:center;justify-content:space-between;height:var(--nav-h);padding:0 5vw;background:rgba(245,240,232,.97);backdrop-filter:blur(16px);border-bottom:1.5px solid var(--border);transition:box-shadow .3s}
nav.scrolled{box-shadow:0 2px 20px rgba(0,0,0,.09)}
.logo{font-family:'Syne',sans-serif;font-weight:800;font-size:1.3rem;color:var(--ink);text-decoration:none;display:flex;align-items:center;gap:8px}
.logo-box{width:28px;height:28px;background:var(--accent);border-radius:3px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:.75rem;font-weight:900;flex-shrink:0}
.logo em{color:var(--accent);font-style:normal}
.nav-links{display:flex;gap:1.8rem;list-style:none;align-items:center}
.nav-links a{font-size:.84rem;font-weight:500;color:var(--ink);text-decoration:none;padding:4px 0;border-bottom:2px solid transparent;transition:all .2s}
.nav-links a:hover,.nav-links a.active{color:var(--accent);border-bottom-color:var(--accent)}
.nav-r{display:flex;align-items:center;gap:.65rem}
.nav-login-btn{font-family:'Syne',sans-serif;font-weight:700;font-size:.76rem;letter-spacing:.04em;padding:8px 18px;border:2px solid var(--ink);background:transparent;color:var(--ink);cursor:pointer;text-transform:uppercase;transition:all .2s}
.nav-login-btn:hover{background:var(--ink);color:var(--paper)}
.nav-reg-btn{font-family:'Syne',sans-serif;font-weight:700;font-size:.76rem;letter-spacing:.04em;padding:9px 18px;background:var(--accent);color:#fff;border:none;cursor:pointer;text-transform:uppercase;transition:background .2s}
.nav-reg-btn:hover{background:#c5350f}
.nav-avatar{display:none;align-items:center;gap:.55rem;position:relative;cursor:pointer}
.av-circle{width:36px;height:36px;border-radius:50%;background:var(--accent);color:#fff;font-family:'Syne',sans-serif;font-weight:800;font-size:.9rem;display:flex;align-items:center;justify-content:center;box-shadow:0 0 0 2px var(--paper),0 0 0 4px var(--accent)}
.av-name{font-size:.83rem;font-weight:600}
.av-drop{display:none;position:absolute;top:calc(100% + 12px);right:0;background:#fff;border:1.5px solid var(--border);min-width:210px;box-shadow:0 14px 40px rgba(0,0,0,.13);z-index:500}
.nav-avatar.open .av-drop{display:block}
.av-drop-head{padding:14px 16px;border-bottom:1px solid var(--border);background:var(--paper)}
.av-drop-name{font-family:'Syne',sans-serif;font-weight:700;font-size:.88rem}
.av-drop-email{font-size:.73rem;color:var(--muted);margin-top:2px}
.av-drop a{display:flex;align-items:center;gap:.5rem;padding:11px 16px;font-size:.82rem;color:var(--ink);text-decoration:none;border-bottom:1px solid var(--border);transition:background .15s}
.av-drop a:last-child{border-bottom:none}
.av-drop a:hover{background:var(--paper)}
.av-drop .logout{color:var(--accent);font-weight:600}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;border:none;background:none;padding:4px}
.hamburger span{width:24px;height:2px;background:var(--ink);display:block}
.mob-menu{display:none;position:fixed;inset:0;top:var(--nav-h);background:var(--paper);z-index:200;flex-direction:column;padding:2rem 5vw;overflow-y:auto;border-top:1.5px solid var(--border)}
.mob-menu.open{display:flex}
.mob-menu a{font-size:1rem;font-weight:600;color:var(--ink);text-decoration:none;padding:.85rem 0;border-bottom:1px solid var(--border)}
.mob-btns{display:flex;flex-direction:column;gap:.75rem;margin-top:1.5rem}

/* HERO */
.hero{display:grid;grid-template-columns:1fr 1fr;align-items:center;min-height:calc(100vh - var(--nav-h) - 34px);padding:3.5rem 5vw;gap:4rem;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;right:-5vw;top:8%;width:48vw;height:48vw;max-width:580px;max-height:580px;border-radius:50%;background:radial-gradient(circle,rgba(232,65,24,.06) 0%,transparent 70%);pointer-events:none}
.hero-eyebrow{display:inline-flex;align-items:center;gap:8px;background:rgba(232,65,24,.08);color:var(--accent);font-size:.73rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:6px 14px;margin-bottom:1.4rem}
.hero h1{font-family:'Syne',sans-serif;font-size:clamp(2.1rem,4vw,3.7rem);font-weight:800;line-height:1.07;margin-bottom:1.3rem}
.hero h1 em{font-style:normal;color:var(--accent);text-decoration:underline;text-decoration-color:var(--accent2);text-underline-offset:6px}
.hero-sub{font-size:.97rem;color:var(--muted);line-height:1.75;margin-bottom:2rem;max-width:460px}
.hero-btns{display:flex;gap:.8rem;flex-wrap:wrap;margin-bottom:2.5rem}
.btn-p{background:var(--accent);color:#fff;font-family:'Syne',sans-serif;font-weight:700;font-size:.84rem;letter-spacing:.04em;padding:13px 28px;border:none;cursor:pointer;text-transform:uppercase;transition:all .2s;text-decoration:none;display:inline-block}
.btn-p:hover{background:#c5350f;transform:translateY(-2px)}
.btn-o{background:transparent;color:var(--ink);font-family:'Syne',sans-serif;font-weight:700;font-size:.84rem;letter-spacing:.04em;padding:12px 28px;border:2px solid var(--ink);cursor:pointer;text-transform:uppercase;transition:all .2s;text-decoration:none;display:inline-block}
.btn-o:hover{background:var(--ink);color:var(--paper)}
.stats-row{display:flex;gap:2.5rem;flex-wrap:wrap}
.stat{display:flex;flex-direction:column}
.stat-n{font-family:'Syne',sans-serif;font-size:1.85rem;font-weight:800;line-height:1}
.stat-n b{color:var(--accent)}
.stat-l{font-size:.72rem;color:var(--muted);margin-top:4px;letter-spacing:.03em}
.hero-visual{display:flex;flex-direction:column;gap:.9rem;animation:floatIn .65s .1s both}
@keyframes floatIn{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
.big-card{background:#fff;border:1.5px solid var(--border);padding:1.3rem;box-shadow:6px 6px 0 var(--ink);position:relative;transition:all .2s}
.big-card:hover{transform:translate(-3px,-3px);box-shadow:9px 9px 0 var(--ink)}
.badge-avail{position:absolute;top:.9rem;right:.9rem;background:var(--green);color:#fff;font-size:.63rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;padding:4px 10px;border-radius:2px}
.card-thumb{width:100%;height:138px;background:linear-gradient(135deg,#efe7d4,#ddd4c0);display:flex;align-items:center;justify-content:center;font-size:2.5rem;border:1px solid var(--border);margin-bottom:.9rem}
.card-name{font-family:'Syne',sans-serif;font-weight:700;font-size:.96rem;margin-bottom:3px}
.card-loc{font-size:.76rem;color:var(--muted);margin-bottom:.7rem}
.card-row{display:flex;justify-content:space-between;align-items:center}
.card-price{font-family:'Syne',sans-serif;font-weight:800;font-size:1.08rem;color:var(--accent)}
.card-tag-sm{font-size:.68rem;color:var(--muted);border:1px solid var(--border);padding:3px 9px;background:var(--paper)}
.mini-row{display:grid;grid-template-columns:1fr 1fr;gap:.7rem}
.mini-c{background:#fff;border:1.5px solid var(--border);padding:.85rem;box-shadow:3px 3px 0 var(--border);transition:all .2s}
.mini-c:hover{box-shadow:3px 3px 0 var(--ink)}
.mini-c .ic{font-size:1.25rem;margin-bottom:.3rem}
.mini-c .mt{font-family:'Syne',sans-serif;font-weight:700;font-size:.79rem}
.mini-c .ms{font-size:.7rem;color:var(--muted);margin-top:2px}

/* DASH BANNER */
.dash-banner{background:linear-gradient(135deg,var(--ink) 0%,#1c2a40 100%);padding:2rem 5vw;display:none}
.dash-inner{display:flex;align-items:center;justify-content:space-between;gap:1.5rem;flex-wrap:wrap}
.dash-greet{font-family:'Syne',sans-serif;font-weight:800;font-size:1.35rem;color:var(--paper)}
.dash-sub{font-size:.82rem;color:rgba(245,240,232,.45);margin-top:4px}
.dash-cards{display:flex;gap:.9rem;flex-wrap:wrap}
.d-card{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);padding:.85rem 1.2rem;min-width:130px;text-align:center}
.d-card-n{font-family:'Syne',sans-serif;font-weight:800;font-size:1.4rem;color:var(--accent2)}
.d-card-l{font-size:.69rem;color:rgba(245,240,232,.42);margin-top:3px}

/* SEARCH */
.search-sec{padding:0 5vw 4rem}
.search-box{background:var(--ink);padding:1.8rem 2.2rem;display:flex;gap:.9rem;flex-wrap:wrap;align-items:flex-end}
.sf{flex:1;min-width:130px}
.sf label{display:block;font-size:.66rem;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:rgba(245,240,232,.42);margin-bottom:6px}
.sf input,.sf select{width:100%;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.11);color:var(--paper);font-family:'DM Sans',sans-serif;font-size:.87rem;padding:9px 12px;outline:none;transition:border-color .2s;-webkit-appearance:none}
.sf input::placeholder{color:rgba(245,240,232,.28)}
.sf input:focus,.sf select:focus{border-color:var(--accent2)}
.sf select option{background:#1a1f2e}
.s-btn{background:var(--accent);color:#fff;font-family:'Syne',sans-serif;font-weight:700;font-size:.82rem;letter-spacing:.05em;padding:10px 26px;border:none;cursor:pointer;text-transform:uppercase;transition:background .2s;align-self:flex-end;white-space:nowrap;flex-shrink:0}
.s-btn:hover{background:#c5350f}

/* CITIES */
.cities-sec{padding:1.5rem 5vw 2rem}
.city-tabs{display:flex;gap:.4rem;flex-wrap:wrap;margin-bottom:.75rem}
.ctab{font-family:'Syne',sans-serif;font-weight:700;font-size:.71rem;letter-spacing:.06em;text-transform:uppercase;padding:7px 16px;border:1.5px solid var(--border);background:#fff;color:var(--muted);cursor:pointer;transition:all .2s}
.ctab.active,.ctab:hover{background:var(--ink);color:var(--paper);border-color:var(--ink)}
.city-meta{font-size:.78rem;color:var(--muted)}
.city-meta strong{color:var(--ink);font-weight:600}

/* SECTIONS */
.sec{padding:4.5rem 5vw}
.sec-alt{padding:4.5rem 5vw;background:#faf7f2}
.sec-hd{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:2.2rem;flex-wrap:wrap;gap:1rem}
.sec-label{font-size:.71rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);margin-bottom:.4rem}
.sec-title{font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(1.5rem,3vw,2.2rem);line-height:1.17}
.see-all{font-size:.79rem;font-weight:600;color:var(--accent);text-decoration:none;border-bottom:1px solid currentColor;padding-bottom:1px;white-space:nowrap}

/* PROP GRID */
.prop-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(268px,1fr));gap:1.4rem}
.pc{background:#fff;border:1.5px solid var(--border);cursor:pointer;transition:all .2s}
.pc:hover{transform:translate(-4px,-4px);box-shadow:6px 6px 0 var(--ink)}
.pc-thumb{width:100%;height:168px;display:flex;align-items:center;justify-content:center;font-size:2.8rem;position:relative}
.pc-thumb.c1{background:#dbeafe}.pc-thumb.c2{background:#d1fae5}.pc-thumb.c3{background:#fef3c7}
.pc-thumb.c4{background:#fce7f3}.pc-thumb.c5{background:#ede9fe}.pc-thumb.c6{background:#ffedd5}
.pc-thumb.c7{background:#e0f2fe}.pc-thumb.c8{background:#dcfce7}.pc-thumb.c9{background:#fef9c3}
.pc-tag{position:absolute;top:10px;left:10px;font-size:.63rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;padding:4px 10px;background:var(--ink);color:var(--paper)}
.pc-tag.pg{background:var(--accent2);color:var(--ink)}
.pc-body{padding:1.1rem}
.pc-name{font-family:'Syne',sans-serif;font-weight:700;font-size:.95rem;margin-bottom:3px}
.pc-loc{font-size:.76rem;color:var(--muted);margin-bottom:.65rem}
.pc-chips{display:flex;gap:.35rem;flex-wrap:wrap;margin-bottom:.7rem}
.chip{font-size:.67rem;color:var(--muted);border:1px solid var(--border);padding:2px 8px}
.pc-ft{display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--border);padding-top:.75rem;margin-top:.4rem}
.pc-price{font-family:'Syne',sans-serif;font-weight:800;font-size:1.05rem;color:var(--accent)}
.pc-price small{font-size:.65rem;font-weight:400;color:var(--muted)}
.c-btn{font-family:'Syne',sans-serif;font-weight:700;font-size:.68rem;letter-spacing:.04em;padding:7px 14px;background:var(--ink);color:#fff;border:none;cursor:pointer;text-transform:uppercase;transition:background .2s}
.c-btn:hover{background:var(--accent)}

/* HOW IT WORKS */
.how-sec{background:var(--ink);padding:4.5rem 5vw}
.how-sec .sec-label{color:var(--accent2)}
.how-sec .sec-title{color:var(--paper)}
.steps{display:grid;grid-template-columns:repeat(auto-fill,minmax(205px,1fr));gap:1.3rem;margin-top:2.5rem}
.step{border:1px solid rgba(245,240,232,.11);padding:1.8rem 1.4rem;transition:border-color .2s;position:relative}
.step:hover{border-color:var(--accent)}
.step-n{font-family:'Syne',sans-serif;font-weight:800;font-size:2.5rem;color:rgba(232,65,24,.16);line-height:1;margin-bottom:.8rem}
.step-ic{font-size:1.6rem;margin-bottom:.75rem}
.step-t{font-family:'Syne',sans-serif;font-weight:700;color:var(--paper);font-size:.93rem;margin-bottom:.4rem}
.step-d{font-size:.81rem;color:rgba(245,240,232,.48);line-height:1.62}

/* PG SECTION */
.pg-sec{background:var(--accent);padding:4.5rem 5vw}
.pg-sec .sec-label{color:rgba(245,240,232,.58)}
.pg-sec .sec-title{color:#fff}
.pg-inner{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start;margin-top:2.2rem}
.pg-desc{color:rgba(255,255,255,.8);font-size:.95rem;line-height:1.75;margin-bottom:1.4rem}
.amenities{display:grid;grid-template-columns:1fr 1fr;gap:.62rem;margin-bottom:1.8rem}
.am{display:flex;align-items:center;gap:.5rem;color:#fff;font-size:.83rem}
.am-dot{width:6px;height:6px;background:var(--accent2);flex-shrink:0}
.pg-rooms{display:flex;flex-direction:column;gap:.75rem}
.pg-room{background:rgba(0,0,0,.14);border-left:3px solid var(--accent2);padding:.95rem 1.25rem;display:flex;justify-content:space-between;align-items:center;transition:background .2s}
.pg-room:hover{background:rgba(0,0,0,.24)}
.pg-rn{font-family:'Syne',sans-serif;font-weight:700;color:#fff;font-size:.88rem}
.pg-rm{font-size:.73rem;color:rgba(255,255,255,.52);margin-top:2px}
.pg-rp{font-family:'Syne',sans-serif;font-weight:800;color:var(--accent2);font-size:1.05rem;white-space:nowrap}

/* WHY */
.why-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(182px,1fr));gap:1.3rem}
.why-c{background:#fff;border:1.5px solid var(--border);padding:1.7rem 1.4rem;text-align:center;transition:all .2s}
.why-c:hover{transform:translateY(-4px);box-shadow:0 14px 30px rgba(0,0,0,.08)}
.why-ic{font-size:1.85rem;margin-bottom:.85rem}
.why-t{font-family:'Syne',sans-serif;font-weight:700;font-size:.88rem;margin-bottom:.4rem}
.why-d{font-size:.77rem;color:var(--muted);line-height:1.62}

/* OWNER SEC */
.owner-sec{background:var(--ink);padding:4.5rem 5vw}
.owner-inner{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center}
.owner-sec .sec-label{color:var(--accent2)}
.owner-sec .sec-title{color:var(--paper);margin-bottom:1rem}
.owner-desc{color:rgba(245,240,232,.58);font-size:.93rem;line-height:1.75;margin-bottom:1.5rem}
.owner-perks{display:flex;flex-direction:column;gap:.65rem;margin-bottom:2rem}
.perk{display:flex;align-items:center;gap:.65rem;color:rgba(245,240,232,.78);font-size:.85rem}
.owner-stats{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.o-stat{border:1px solid rgba(245,240,232,.11);padding:1.2rem;text-align:center}
.o-stat-n{font-family:'Syne',sans-serif;font-weight:800;font-size:1.65rem;color:var(--accent2)}
.o-stat-l{font-size:.72rem;color:rgba(245,240,232,.4);margin-top:3px}

/* TESTIMONIALS */
.test-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(265px,1fr));gap:1.3rem}
.tc{background:#fff;border:1.5px solid var(--border);padding:1.8rem}
.tc-stars{color:var(--accent2);font-size:.73rem;margin-bottom:.3rem}
.tc-q{font-size:2.7rem;color:var(--accent);font-family:Georgia,serif;line-height:1;margin-bottom:.25rem}
.tc-text{font-size:.84rem;color:var(--muted);line-height:1.75;margin-bottom:1.3rem}
.tc-auth{display:flex;align-items:center;gap:.7rem}
.tc-av{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.15rem;flex-shrink:0;border:2px solid var(--border)}
.tc-name{font-family:'Syne',sans-serif;font-weight:700;font-size:.84rem}
.tc-role{font-size:.72rem;color:var(--muted);margin-top:2px}

/* CTA */
.cta-sec{padding:4.5rem 5vw;border-top:2px solid var(--ink);display:flex;justify-content:space-between;align-items:center;gap:3rem;flex-wrap:wrap}
.cta-sec .sec-title span{color:var(--accent)}
.cta-bts{display:flex;gap:.8rem;flex-wrap:wrap}

/* FOOTER */
footer{background:var(--ink);padding:4rem 5vw 2rem}
.footer-g{display:grid;grid-template-columns:2fr 1fr 1fr 1fr 1fr;gap:2.5rem;margin-bottom:3rem}
.footer-brand p{font-size:.81rem;color:rgba(245,240,232,.38);line-height:1.72;margin-top:.9rem;max-width:240px}
.footer-badge{display:inline-flex;align-items:center;gap:.4rem;background:rgba(255,255,255,.05);padding:6px 12px;margin-top:1rem;font-size:.7rem;color:rgba(245,240,232,.38);border:1px solid rgba(245,240,232,.09)}
.f-title{font-family:'Syne',sans-serif;font-weight:700;font-size:.78rem;color:var(--paper);letter-spacing:.07em;text-transform:uppercase;margin-bottom:1.1rem}
.f-links{list-style:none;display:flex;flex-direction:column;gap:.52rem}
.f-links a{font-size:.8rem;color:rgba(245,240,232,.38);text-decoration:none;transition:color .2s}
.f-links a:hover{color:var(--paper)}
.f-bottom{border-top:1px solid rgba(245,240,232,.07);padding-top:1.5rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem}
.f-copy{font-size:.73rem;color:rgba(245,240,232,.25)}
.f-socials{display:flex;gap:.6rem}
.fsoc{width:30px;height:30px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.09);display:flex;align-items:center;justify-content:center;font-size:.78rem;cursor:pointer;transition:background .2s;text-decoration:none;color:rgba(245,240,232,.5)}
.fsoc:hover{background:var(--accent);color:#fff}

/* MODALS */
.overlay{display:none;position:fixed;inset:0;background:rgba(13,17,23,.72);z-index:1000;align-items:center;justify-content:center;padding:1rem}
.overlay.open{display:flex}
.modal{background:var(--paper);width:100%;max-width:480px;position:relative;border:2px solid var(--ink);animation:popIn .22s ease both;max-height:90vh;overflow-y:auto}
@keyframes popIn{from{opacity:0;transform:scale(.95)}to{opacity:1;transform:scale(1)}}
.modal-hd{padding:1.7rem 2rem 1.1rem;border-bottom:1.5px solid var(--border);position:sticky;top:0;background:var(--paper);z-index:2}
.modal-title{font-family:'Syne',sans-serif;font-weight:800;font-size:1.3rem}
.modal-sub{font-size:.81rem;color:var(--muted);margin-top:4px}
.modal-close{position:absolute;top:1.1rem;right:1.2rem;background:none;border:none;font-size:1.25rem;cursor:pointer;color:var(--muted);transition:color .2s}
.modal-close:hover{color:var(--ink)}
.modal-body{padding:1.5rem 2rem 2rem}
.tab-row{display:flex;border-bottom:2px solid var(--border);margin-bottom:1.5rem}
